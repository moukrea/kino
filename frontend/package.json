{
  "name": "kino-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "kino SolidJS frontend bundle (shared across Linux, Android, Android TV).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
